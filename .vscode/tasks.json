{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Build",
            "type": "shell",
            "command": "cmd",
            "args": ["/c", "${workspaceFolder}\\.vscode\\build.bat"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Run InvaderGame",
            "type": "shell",
            "command": ".\\build\\InvaderGame.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "CMake: Build",
            "problemMatcher": []
        }
    ]
}